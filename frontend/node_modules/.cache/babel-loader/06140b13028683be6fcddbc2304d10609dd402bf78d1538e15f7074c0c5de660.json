{"ast":null,"code":"import \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.for-each.js\";\nexport default {\n  name: \"ContactPage\",\n  data() {\n    return {\n      form: {\n        firstName: \"\",\n        lastName: \"\",\n        email: \"\",\n        phone: \"\",\n        message: \"\"\n      }\n    };\n  },\n  methods: {\n    submitForm() {\n      alert(\"Thank you for reaching out! We will be in touch shortly.\");\n      this.form = {\n        firstName: \"\",\n        lastName: \"\",\n        email: \"\",\n        phone: \"\",\n        message: \"\"\n      };\n    }\n  },\n  directives: {\n    animateOnScroll: {\n      mounted(el) {\n        const observer = new IntersectionObserver(entries => {\n          entries.forEach(entry => {\n            if (entry.isIntersecting) {\n              el.classList.add('is-visible');\n              observer.unobserve(el);\n            }\n          });\n        }, {\n          threshold: 0.1\n        });\n        observer.observe(el);\n      }\n    }\n  }\n};","map":{"version":3,"names":["name","data","form","firstName","lastName","email","phone","message","methods","submitForm","alert","directives","animateOnScroll","mounted","el","observer","IntersectionObserver","entries","forEach","entry","isIntersecting","classList","add","unobserve","threshold","observe"],"sources":["C:\\Users\\LENOVO\\Music\\OneDrive\\Pictures\\distribution-agency-project\\frontend\\src\\views\\Contact.vue"],"sourcesContent":["<template>\r\n  <div class=\"contact-page\">\r\n    <!-- Immersive Header Section -->\r\n    <section class=\"contact-hero\">\r\n      <div class=\"hero-overlay\"></div>\r\n      <div class=\"hero-content\" v-animate-on-scroll>\r\n        <h1 class=\"page-title\">Contact Us</h1>\r\n        <p class=\"page-subtitle\">We would love to hear from you. Let's start a conversation.</p>\r\n      </div>\r\n      <div class=\"scroll-indicator\">\r\n        <div class=\"mouse\"></div>\r\n      </div>\r\n    </section>\r\n\r\n    <!-- Main Contact Section -->\r\n    <section class=\"main-contact container\">\r\n      <div class=\"redesign-grid\">\r\n        <!-- Info Column with Enhanced Cards -->\r\n        <div class=\"info-column\">\r\n          <div class=\"section-intro\" v-animate-on-scroll>\r\n            <h2 class=\"script-title\">Get In Touch</h2>\r\n            <p>Our team is here to help you with any questions or concerns you might have. Reach out via any of the channels below.</p>\r\n          </div>\r\n\r\n          <div class=\"contact-cards\">\r\n            <div class=\"contact-card\" v-animate-on-scroll :style=\"{ transitionDelay: '0.1s' }\">\r\n              <div class=\"card-icon\"><i class=\"fas fa-map-marked-alt\"></i></div>\r\n              <div class=\"card-body\">\r\n                <h3>Main Office</h3>\r\n                <p>Kattappana, Idukki District<br/>Kerala, India 685508</p>\r\n              </div>\r\n            </div>\r\n\r\n            <div class=\"contact-card\" v-animate-on-scroll :style=\"{ transitionDelay: '0.2s' }\">\r\n              <div class=\"card-icon\"><i class=\"fas fa-phone-volume\"></i></div>\r\n              <div class=\"card-body\">\r\n                <h3>Phone</h3>\r\n                <p>+91 97452 79543<br/>+91 94478 21456</p>\r\n              </div>\r\n            </div>\r\n\r\n            <div class=\"contact-card\" v-animate-on-scroll :style=\"{ transitionDelay: '0.3s' }\">\r\n              <div class=\"card-icon\"><i class=\"fas fa-paper-plane\"></i></div>\r\n              <div class=\"card-body\">\r\n                <h3>Email</h3>\r\n                <p>cochindistributors@gmail.com<br/>support@cochin.dist</p>\r\n              </div>\r\n            </div>\r\n          </div>\r\n\r\n          <div class=\"social-box\" v-animate-on-scroll>\r\n            <span>Follow our journey</span>\r\n            <div class=\"social-icons\">\r\n              <a href=\"#\" class=\"social-btn facebook\"><i class=\"fab fa-facebook-f\"></i></a>\r\n              <a href=\"#\" class=\"social-btn instagram\"><i class=\"fab fa-instagram\"></i></a>\r\n              <a href=\"#\" class=\"social-btn twitter\"><i class=\"fab fa-twitter\"></i></a>\r\n              <a href=\"#\" class=\"social-btn youtube\"><i class=\"fab fa-youtube\"></i></a>\r\n            </div>\r\n          </div>\r\n        </div>\r\n\r\n        <!-- Premium Form Column -->\r\n        <div class=\"form-column\" v-animate-on-scroll>\r\n          <div class=\"form-premium-card\">\r\n            <div class=\"card-header\">\r\n              <i class=\"fas fa-envelope-open-text\"></i>\r\n              <h3>Send a Message</h3>\r\n            </div>\r\n            <form @submit.prevent=\"submitForm\">\r\n              <div class=\"input-row\">\r\n                <div class=\"input-group\">\r\n                  <input type=\"text\" v-model=\"form.firstName\" required placeholder=\" \" />\r\n                  <label>First Name</label>\r\n                  <div class=\"bar\"></div>\r\n                </div>\r\n                <div class=\"input-group\">\r\n                  <input type=\"text\" v-model=\"form.lastName\" required placeholder=\" \" />\r\n                  <label>Last Name</label>\r\n                  <div class=\"bar\"></div>\r\n                </div>\r\n              </div>\r\n\r\n              <div class=\"input-group\">\r\n                <input type=\"email\" v-model=\"form.email\" required placeholder=\" \" />\r\n                <label>Email Address</label>\r\n                <div class=\"bar\"></div>\r\n              </div>\r\n\r\n              <div class=\"input-group\">\r\n                <input type=\"tel\" v-model=\"form.phone\" placeholder=\" \" />\r\n                <label>Phone (Optional)</label>\r\n                <div class=\"bar\"></div>\r\n              </div>\r\n\r\n              <div class=\"input-group\">\r\n                <textarea v-model=\"form.message\" rows=\"4\" required placeholder=\" \"></textarea>\r\n                <label>How can we help?</label>\r\n                <div class=\"bar\"></div>\r\n              </div>\r\n\r\n              <button type=\"submit\" class=\"btn-premium\">\r\n                <span>Submit Message</span>\r\n                <i class=\"fas fa-long-arrow-alt-right\"></i>\r\n              </button>\r\n            </form>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </section>\r\n\r\n    <!-- Map Section with decorative framing -->\r\n    <section class=\"map-immersive\">\r\n      <div class=\"container map-wrapper\">\r\n        <div class=\"map-frame\" v-animate-on-scroll>\r\n          <div class=\"map-inner\">\r\n             <div class=\"map-marker-floating\">\r\n               <div class=\"pin\"></div>\r\n               <div class=\"pulse\"></div>\r\n             </div>\r\n             <img src=\"https://images.unsplash.com/photo-1526778548025-fa2f459cd5c1?auto=format&fit=crop&q=80&w=1200\" alt=\"Map Location\" />\r\n          </div>\r\n          <div class=\"map-details\">\r\n            <h2>Find Us Here</h2>\r\n            <p>Visit us for the freshest experience!</p>\r\n            <button class=\"btn-link\">Open in Maps <i class=\"fas fa-external-link-alt\"></i></button>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </section>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"ContactPage\",\r\n  data() {\r\n    return {\r\n      form: {\r\n        firstName: \"\",\r\n        lastName: \"\",\r\n        email: \"\",\r\n        phone: \"\",\r\n        message: \"\",\r\n      },\r\n    };\r\n  },\r\n  methods: {\r\n    submitForm() {\r\n      alert(\"Thank you for reaching out! We will be in touch shortly.\");\r\n      this.form = {\r\n        firstName: \"\",\r\n        lastName: \"\",\r\n        email: \"\",\r\n        phone: \"\",\r\n        message: \"\",\r\n      };\r\n    },\r\n  },\r\n  directives: {\r\n    animateOnScroll: {\r\n      mounted(el) {\r\n        const observer = new IntersectionObserver((entries) => {\r\n          entries.forEach(entry => {\r\n            if (entry.isIntersecting) {\r\n              el.classList.add('is-visible');\r\n              observer.unobserve(el);\r\n            }\r\n          });\r\n        }, { threshold: 0.1 });\r\n        observer.observe(el);\r\n      }\r\n    }\r\n  }\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n.contact-page {\r\n  font-family: 'Plus Jakarta Sans', sans-serif;\r\n  color: #4a372d;\r\n  background-color: #fffaf5;\r\n  padding-top: 80px;\r\n  overflow-x: hidden;\r\n}\r\n\r\n.container {\r\n  max-width: 1240px;\r\n  margin: 0 auto;\r\n  padding: 0 2rem;\r\n}\r\n\r\n/* --- Hero Section --- */\r\n.contact-hero {\r\n  height: 40vh;\r\n  position: relative;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  text-align: center;\r\n  background: url('https://images.unsplash.com/photo-1555507036-ab1f4038808a?auto=format&fit=crop&q=80&w=1400') center/cover no-repeat fixed;\r\n}\r\n\r\n.hero-overlay {\r\n  position: absolute;\r\n  inset: 0;\r\n  background: rgba(62, 39, 35, 0.4);\r\n}\r\n\r\n.page-title {\r\n  position: relative;\r\n  z-index: 1;\r\n  font-family: 'Dancing Script', cursive;\r\n  font-size: clamp(3.5rem, 8vw, 5.5rem);\r\n  color: white;\r\n  font-weight: 700;\r\n  margin-bottom: 0.5rem;\r\n  text-shadow: 0 4px 10px rgba(0,0,0,0.3);\r\n}\r\n\r\n.page-subtitle {\r\n  position: relative;\r\n  z-index: 1;\r\n  font-size: 1.25rem;\r\n  color: #fffaf5;\r\n  font-weight: 500;\r\n  max-width: 600px;\r\n  margin: 0 auto;\r\n  opacity: 0.9;\r\n}\r\n\r\n.scroll-indicator {\r\n  position: absolute;\r\n  bottom: 30px;\r\n  left: 50%;\r\n  transform: translateX(-50%);\r\n  z-index: 2;\r\n}\r\n\r\n.mouse {\r\n  width: 25px;\r\n  height: 40px;\r\n  border: 2px solid white;\r\n  border-radius: 20px;\r\n  display: flex;\r\n  justify-content: center;\r\n  padding-top: 5px;\r\n}\r\n\r\n.mouse::before {\r\n  content: '';\r\n  width: 3px;\r\n  height: 10px;\r\n  background: white;\r\n  border-radius: 2px;\r\n  animation: scrollDown 2s infinite ease-out;\r\n}\r\n\r\n@keyframes scrollDown {\r\n  0% { transform: translateY(0); opacity: 1; }\r\n  100% { transform: translateY(15px); opacity: 0; }\r\n}\r\n\r\n/* --- Main Section Grid --- */\r\n.main-contact {\r\n  padding: 10rem 0;\r\n}\r\n\r\n.redesign-grid {\r\n  display: grid;\r\n  grid-template-columns: 1fr 1.3fr;\r\n  gap: 8rem;\r\n  align-items: start;\r\n}\r\n\r\n/* --- Info Column --- */\r\n.section-intro {\r\n  margin-bottom: 4rem;\r\n  opacity: 0;\r\n  transform: translateY(20px);\r\n  transition: all 0.8s ease;\r\n}\r\n\r\n.section-intro.is-visible {\r\n  opacity: 1; transform: translateY(0);\r\n}\r\n\r\n.script-title {\r\n  font-family: 'Dancing Script', cursive;\r\n  font-size: 3.5rem;\r\n  color: #3e2723;\r\n  margin-bottom: 1.5rem;\r\n}\r\n\r\n.section-intro p {\r\n  line-height: 1.8;\r\n  color: #795548;\r\n  font-size: 1.1rem;\r\n}\r\n\r\n.contact-cards {\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: 2rem;\r\n  margin-bottom: 4rem;\r\n}\r\n\r\n.contact-card {\r\n  background: white;\r\n  padding: 2.5rem;\r\n  border-radius: 16px;\r\n  display: flex;\r\n  gap: 1.5rem;\r\n  align-items: center;\r\n  box-shadow: 0 10px 30px rgba(74, 55, 45, 0.04);\r\n  transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);\r\n  opacity: 0;\r\n  transform: translateX(-30px);\r\n}\r\n\r\n.contact-card.is-visible {\r\n  opacity: 1; transform: translateX(0);\r\n}\r\n\r\n.contact-card:hover {\r\n  transform: translateY(-8px) scale(1.02);\r\n  box-shadow: 0 20px 50px rgba(74, 55, 45, 0.08);\r\n}\r\n\r\n.card-icon {\r\n  width: 65px;\r\n  height: 65px;\r\n  background: #fff5eb;\r\n  color: #efa962;\r\n  border-radius: 14px;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  font-size: 1.8rem;\r\n  flex-shrink: 0;\r\n  transition: all 0.3s ease;\r\n}\r\n\r\n.contact-card:hover .card-icon {\r\n  background: #efa962;\r\n  color: white;\r\n  transform: rotate(10deg);\r\n}\r\n\r\n.card-body h3 {\r\n  font-size: 1.35rem;\r\n  margin-bottom: 0.5rem;\r\n  color: #3e2723;\r\n}\r\n\r\n.card-body p {\r\n  color: #8d6e63;\r\n  line-height: 1.6;\r\n}\r\n\r\n.social-box {\r\n  background: #3e2723;\r\n  padding: 2rem;\r\n  border-radius: 16px;\r\n  color: white;\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: center;\r\n  gap: 1.5rem;\r\n  opacity: 0;\r\n  transform: scale(0.9);\r\n  transition: all 0.6s ease;\r\n}\r\n\r\n.social-box.is-visible {\r\n  opacity: 1; transform: scale(1);\r\n}\r\n\r\n.social-icons {\r\n  display: flex;\r\n  gap: 1.2rem;\r\n}\r\n\r\n.social-btn {\r\n  width: 48px;\r\n  height: 48px;\r\n  background: rgba(255,255,255,0.1);\r\n  border-radius: 50%;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  color: white;\r\n  font-size: 1.25rem;\r\n  transition: all 0.3s ease;\r\n  text-decoration: none;\r\n}\r\n\r\n.social-btn:hover {\r\n  background: #efa962;\r\n  transform: translateY(-5px);\r\n}\r\n\r\n/* --- Form Column --- */\r\n.form-premium-card {\r\n  background: white;\r\n  padding: 4.5rem;\r\n  border-radius: 24px;\r\n  box-shadow: 0 40px 100px rgba(74, 55, 45, 0.07);\r\n  position: relative;\r\n  overflow: hidden;\r\n  opacity: 0;\r\n  transform: translateX(30px);\r\n  transition: all 1s ease;\r\n}\r\n\r\n.form-premium-card.is-visible {\r\n  opacity: 1; transform: translateX(0);\r\n}\r\n\r\n.form-premium-card::before {\r\n  content: '';\r\n  position: absolute;\r\n  top: 0; left: 0; width: 6px; height: 100%;\r\n  background: #efa962;\r\n}\r\n\r\n.card-header {\r\n  margin-bottom: 3.5rem;\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 1.2rem;\r\n}\r\n\r\n.card-header i { font-size: 2.5rem; color: #efa962; }\r\n.card-header h3 { font-family: 'Dancing Script', cursive; font-size: 2.8rem; color: #3e2723; }\r\n\r\n.input-row {\r\n  display: grid;\r\n  grid-template-columns: 1fr 1fr;\r\n  gap: 2rem;\r\n}\r\n\r\n.input-group {\r\n  position: relative;\r\n  margin-bottom: 3rem;\r\n}\r\n\r\n.input-group input,\r\n.input-group textarea {\r\n  width: 100%;\r\n  padding: 12px 10px 10px 5px;\r\n  display: block;\r\n  border: none;\r\n  border-bottom: 2px solid #e0d5d0;\r\n  background: transparent;\r\n  font-size: 1.1rem;\r\n  color: #3e2723;\r\n  transition: all 0.3s ease;\r\n}\r\n\r\n.input-group input:focus,\r\n.input-group textarea:focus {\r\n  outline: none;\r\n}\r\n\r\n.input-group label {\r\n  color: #8d6e63;\r\n  font-size: 1.05rem;\r\n  font-weight: 500;\r\n  position: absolute;\r\n  pointer-events : none;\r\n  left: 5px;\r\n  top: 10px;\r\n  transition: all 0.3s ease;\r\n}\r\n\r\n.input-group input:focus ~ label,\r\n.input-group input:not(:placeholder-shown) ~ label,\r\n.input-group textarea:focus ~ label,\r\n.input-group textarea:not(:placeholder-shown) ~ label {\r\n  top: -20px;\r\n  font-size: 0.9rem;\r\n  color: #efa962;\r\n  font-weight: 700;\r\n}\r\n\r\n.bar {\r\n  position: relative;\r\n  display: block;\r\n  width: 100%;\r\n}\r\n\r\n.bar:before, .bar:after {\r\n  content: '';\r\n  height: 2px;\r\n  width: 0;\r\n  bottom: 0px;\r\n  position: absolute;\r\n  background: #efa962;\r\n  transition: all 0.3s ease;\r\n}\r\n\r\n.bar:before { left: 50%; }\r\n.bar:after { right: 50%; }\r\n\r\n.input-group input:focus ~ .bar:before, .input-group input:focus ~ .bar:after,\r\n.input-group textarea:focus ~ .bar:before, .input-group textarea:focus ~ .bar:after {\r\n  width: 50%;\r\n}\r\n\r\n.btn-premium {\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  gap: 1.2rem;\r\n  width: 100%;\r\n  padding: 1.5rem;\r\n  background: #3e2723;\r\n  color: white;\r\n  border: none;\r\n  border-radius: 12px;\r\n  font-weight: 700;\r\n  font-size: 1.1rem;\r\n  cursor: pointer;\r\n  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);\r\n  margin-top: 2rem;\r\n}\r\n\r\n.btn-premium:hover {\r\n  background: #efa962;\r\n  transform: translateY(-3px);\r\n  box-shadow: 0 15px 30px rgba(239, 169, 98, 0.3);\r\n}\r\n\r\n/* --- Map Immersive --- */\r\n.map-immersive {\r\n  padding-bottom: 10rem;\r\n}\r\n\r\n.map-frame {\r\n  display: flex;\r\n  background: white;\r\n  border-radius: 30px;\r\n  overflow: hidden;\r\n  box-shadow: 0 40px 100px rgba(74, 55, 45, 0.08);\r\n  opacity: 0;\r\n  transform: translateY(40px);\r\n  transition: all 1s ease;\r\n}\r\n\r\n.map-frame.is-visible {\r\n  opacity: 1; transform: translateY(0);\r\n}\r\n\r\n.map-inner {\r\n  flex: 1.5;\r\n  height: 500px;\r\n  position: relative;\r\n}\r\n\r\n.map-inner img {\r\n  width: 100%;\r\n  height: 100%;\r\n  object-fit: cover;\r\n}\r\n\r\n.map-marker-floating {\r\n  position: absolute;\r\n  top: 50%; left: 50%;\r\n  transform: translate(-50%, -100%);\r\n  z-index: 5;\r\n}\r\n\r\n.pin {\r\n  width: 30px; height: 30px;\r\n  border-radius: 50% 50% 50% 0;\r\n  background: #efa962;\r\n  transform: rotate(-45deg);\r\n  position: relative;\r\n  box-shadow: 0 10px 20px rgba(0,0,0,0.2);\r\n}\r\n\r\n.pin::after {\r\n  content: '';\r\n  width: 14px; height: 14px;\r\n  margin: 8px 0 0 8px;\r\n  background: #3e2723;\r\n  position: absolute;\r\n  border-radius: 50%;\r\n}\r\n\r\n.pulse {\r\n  background: rgba(239,169,98,0.5);\r\n  border-radius: 50%;\r\n  height: 40px; width: 40px;\r\n  position: absolute;\r\n  left: 50%; top: 50%;\r\n  transform: translate(-50%, -50%);\r\n  z-index: -2;\r\n  animation: pulsePin 2s infinite;\r\n}\r\n\r\n@keyframes pulsePin {\r\n  0% { transform: translate(-50%, -50%) scale(0.1); opacity: 0; }\r\n  50% { opacity: 0.6; }\r\n  100% { transform: translate(-50%, -50%) scale(2); opacity: 0; }\r\n}\r\n\r\n.map-details {\r\n  flex: 1;\r\n  padding: 5rem;\r\n  display: flex;\r\n  flex-direction: column;\r\n  justify-content: center;\r\n  background: #fffdfc;\r\n}\r\n\r\n.map-details h2 { font-family: 'Dancing Script', cursive; font-size: 3rem; margin-bottom: 1.5rem; color: #3e2723; }\r\n.map-details p { font-size: 1.15rem; color: #8d6e63; margin-bottom: 2.5rem; line-height: 1.6; 