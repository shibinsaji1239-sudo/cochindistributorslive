tton\", {\n      onClick: $event => $options.deleteMessageForEveryone(msg._id),\n      class: \"delete-option\"\n    }, \" Delete for everyone \", 8 /* PROPS */, _hoisted_31), _createElementVNode(\"button\", {\n      onClick: _cache[1] || (_cache[1] = $event => $data.deleteMenuId = null),\n      class: \"delete-option\"\n    }, \" Cancel \")])) : _createCommentVNode(\"v-if\", true)], 42 /* CLASS, PROPS, NEED_HYDRATION */, _hoisted_21);\n  }), 128 /* KEYED_FRAGMENT */)), $data.messages.length === 0 ? (_openBlock(), _createElementBlock(\"div\", _hoisted_32, _cache[9] || (_cache[9] = [_createElementVNode(\"span\", {\n    class: \"empty-emoji\"\n  }, \"👋\", -1 /* CACHED */), _createElementVNode(\"p\", null, \"Start a conversation\", -1 /* CACHED */)]))) : _createCommentVNode(\"v-if\", true)], 512 /* NEED_PATCH */), _createElementVNode(\"div\", _hoisted_33, [_withDirectives(_createElementVNode(\"input\", {\n    \"onUpdate:modelValue\": _cache[3] || (_cache[3] = $event => $data.newMessage = $event),\n    onKeyup: _cache[4] || (_cache[4] = _withKeys((...args) => $options.sendMessage && $options.sendMessage(...args), [\"enter\"])),\n    type: \"text\",\n    placeholder: \"Type your message...\",\n    class: \"message-input\"\n  }, null, 544 /* NEED_HYDRATION, NEED_PATCH */), [[_vModelText, $data.newMessage]]), _createElementVNode(\"button\", {\n    onClick: _cache[5] || (_cache[5] = (...args) => $options.sendMessage && $options.sendMessage(...args)),\n    disabled: !$data.newMessage.trim() || $data.sending,\n    class: \"send-btn\"\n  }, [!$data.sending ? (_openBlock(), _createElementBlock(\"span\", _hoisted_35, \"📤\")) : (_openBlock(), _createElementBlock(\"span\", _hoisted_36, \"⏳\"))], 8 /* PROPS */, _hoisted_34)])])) : (_openBlock(), _createElementBlock(\"div\", _hoisted_37, _cache[10] || (_cache[10] = [_createElementVNode(\"div\", {\n    class: \"empty-state\"\n  }, [_createElementVNode(\"span\", {\n    class: \"empty-icon\"\n  }, \"💬\"), _createElementVNode(\"h3\", null, \"Select a contact to start chatting\")], -1 /* CACHED */)])))], 2 /* CLASS */)]);\n}","map":{"version":3,"names":["class","ref","_createElementBlock","_hoisted_1","_createElementVNode","_normalizeClass","$data","selectedContact","_hoisted_2","unreadCount","_hoisted_3","_toDisplayString","type","placeholder","_hoisted_4","_Fragment","_renderList","contacts","contact","key","email","onClick","$event","$options","selectContact","_hoisted_6","src","profilePhoto","apiBase","defaultAvatar","alt","name","isAdmin","_hoisted_8","_hoisted_9","_hoisted_10","_hoisted_11","_hoisted_12","_hoisted_13","length","_hoisted_14","_hoisted_15","_hoisted_16","_cache","_hoisted_18","_hoisted_19","_hoisted_20","messages","msg","_id","senderEmail","userEmail","onMouseenter","hoveredMessageId","onMouseleave","deleted","isMessageDeleted","_hoisted_22","_hoisted_23","message","_hoisted_24","_hoisted_25","formatTime","timestamp","_hoisted_26","_hoisted_27","deleteMessageForMe","title","_hoisted_28","showDeleteMenu","_hoisted_29","deleteMenuId","_hoisted_30","deleteMessageForEveryone","_hoisted_31","_hoisted_32","_hoisted_33","newMessage","onKeyup","_withKeys","args","sendMessage","disabled","trim","sending","_hoisted_35","_hoisted_36","_hoisted_37"],"sources":["C:\\Users\\LENOVO\\Music\\OneDrive\\Pictures\\distribution-agency-project\\frontend\\src\\views\\ChatWindow.vue"],"sourcesContent":["<template>\r\n  <div class=\"chat-container\">\r\n    <div class=\"chat-sidebar\" :class=\"{ 'mobile-hidden': selectedContact }\">\r\n      <div class=\"chat-header\">\r\n        <h3>💬 Messages</h3>\r\n        <span v-if=\"unreadCount > 0\" class=\"unread-badge\">{{\r\n          unreadCount\r\n        }}</span>\r\n      </div>\r\n\r\n      <div class=\"search-box\">\r\n        <input\r\n          type=\"text\"\r\n          placeholder=\"Search contacts...\"\r\n          class=\"search-input\"\r\n        />\r\n      </div>\r\n\r\n      <div class=\"chat-list\">\r\n        <div\r\n          v-for=\"contact in contacts\"\r\n          :key=\"contact.email\"\r\n          @click=\"selectContact(contact)\"\r\n          :class=\"[\r\n            'chat-item',\r\n            {\r\n              active:\r\n                selectedContact && selectedContact.email === contact.email,\r\n            },\r\n          ]\"\r\n        >\r\n          <div class=\"chat-item-avatar\">\r\n            <img\r\n              :src=\"\r\n                contact.profilePhoto\r\n                  ? apiBase + contact.profilePhoto\r\n                  : defaultAvatar\r\n              \"\r\n              :alt=\"contact.name\"\r\n              class=\"avatar-img\"\r\n            />\r\n            <span v-if=\"contact.isAdmin\" class=\"admin-badge\">A</span>\r\n            <span class=\"online-indicator\"></span>\r\n          </div>\r\n          <div class=\"chat-item-content\">\r\n            <div class=\"chat-item-name\">{{ contact.name }}</div>\r\n            <div v-if=\"contact.unreadCount > 0\" class=\"unread-indicator\">\r\n              {{ contact.unreadCount }} new\r\n            </div>\r\n            <div v-else class=\"last-message\">Online now</div>\r\n          </div>\r\n          <span v-if=\"contact.unreadCount > 0\" class=\"unread-dot\"></span>\r\n        </div>\r\n\r\n        <div v-if=\"contacts.length === 0\" class=\"no-contacts\">\r\n          No contacts available\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <div class=\"chat-main\" :class=\"{ 'mobile-hidden': !selectedContact }\">\r\n      <div v-if=\"selectedContact\" class=\"chat-window\">\r\n        <div class=\"chat-header-window\">\r\n          <button class=\"back-btn\" @click=\"selectedContact = null\">←</button>\r\n          <img\r\n            :src=\"\r\n              selectedContact.profilePhoto\r\n                ? apiBase + selectedContact.profilePhoto\r\n                : defaultAvatar\r\n            \"\r\n            :alt=\"selectedContact.name\"\r\n            class=\"header-avatar\"\r\n          />\r\n          <div class=\"header-info\">\r\n            <h4>{{ selectedContact.name }}</h4>\r\n            <span v-if=\"selectedContact.isAdmin\" class=\"admin-label\"\r\n              >Administrator</span\r\n            >\r\n          </div>\r\n        </div>\r\n\r\n        <div class=\"messages-container\" ref=\"messagesContainer\">\r\n          <div\r\n            v-for=\"msg in messages\"\r\n            :key=\"msg._id\"\r\n            :class=\"[\r\n              'message-wrapper',\r\n              {\r\n                sent: msg.senderEmail === userEmail,\r\n                received: msg.senderEmail !== userEmail,\r\n              },\r\n            ]\"\r\n            @mouseenter=\"hoveredMessageId = msg._id\"\r\n            @mouseleave=\"hoveredMessageId = null\"\r\n          >\r\n            <div class=\"message\" :class=\"{ deleted: isMessageDeleted(msg) }\">\r\n              <div\r\n                v-if=\"isMessageDeleted(msg)\"\r\n                class=\"message-content deleted-text\"\r\n              >\r\n                This message was deleted\r\n              </div>\r\n              <div v-else class=\"message-content\">{{ msg.message }}</div>\r\n              <div class=\"message-footer\">\r\n                <span class=\"message-time\">{{\r\n                  formatTime(msg.timestamp)\r\n                }}</span>\r\n                <span\r\n                  v-if=\"msg.senderEmail === userEmail && !isMessageDeleted(msg)\"\r\n                  class=\"checkmark\"\r\n                  >✓✓</span\r\n                >\r\n              </div>\r\n            </div>\r\n\r\n            <div\r\n              v-if=\"\r\n                hoveredMessageId === msg._id &&\r\n                msg.senderEmail === userEmail &&\r\n                !isMessageDeleted(msg)\r\n              \"\r\n              class=\"message-actions\"\r\n            >\r\n              <button\r\n                @click=\"deleteMessageForMe(msg._id)\"\r\n                class=\"delete-btn\"\r\n                title=\"Delete\"\r\n              >\r\n                🗑️\r\n              </button>\r\n              <button\r\n                @click=\"showDeleteMenu(msg._id)\"\r\n                class=\"more-btn\"\r\n                title=\"More options\"\r\n              >\r\n                ⋮\r\n              </button>\r\n            </div>\r\n\r\n            <div\r\n              v-if=\"deleteMenuId === msg._id && msg.senderEmail === userEmail\"\r\n              class=\"delete-menu\"\r\n            >\r\n              <button\r\n                @click=\"deleteMessageForEveryone(msg._id)\"\r\n                class=\"delete-option\"\r\n              >\r\n                Delete for everyone\r\n              </button>\r\n              <button @click=\"deleteMenuId = null\" class=\"delete-option\">\r\n                Cancel\r\n              </button>\r\n            </div>\r\n          </div>\r\n\r\n          <div v-if=\"messages.length === 0\" class=\"no-messages\">\r\n            <span class=\"empty-emoji\">👋</span>\r\n            <p>Start a conversation</p>\r\n          </div>\r\n        </div>\r\n\r\n        <div class=\"chat-input-area\">\r\n          <input\r\n            v-model=\"newMessage\"\r\n            @keyup.enter=\"sendMessage\"\r\n            type=\"text\"\r\n            placeholder=\"Type your message...\"\r\n            class=\"message-input\"\r\n          />\r\n          <button\r\n            @click=\"sendMessage\"\r\n            :disabled=\"!newMessage.trim() || sending\"\r\n            class=\"send-btn\"\r\n          >\r\n            <span v-if=\"!sending\">📤</span>\r\n            <span v-else>⏳</span>\r\n          </button>\r\n        </div>\r\n      </div>\r\n\r\n      <div v-else class=\"no-contact-selected\">\r\n        <div class=\"empty-state\">\r\n          <span class=\"empty-icon\">💬</span>\r\n          <h3>Select a contact to start chatting</h3>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport axios from \"@/utils/axios\";\r\n\r\nexport default {\r\n  name: \"ChatWindow\",\r\n  data() {\r\n    return {\r\n      contacts: [],\r\n      selectedContact: null,\r\n      messages: [],\r\n      newMessage: \"\",\r\n      loading: false,\r\n      sending: false,\r\n      userEmail: \"\",\r\n      apiBase: \"\",\r\n      defaultAvatar: \"/default-avatar.png\",\r\n      unreadCount: 0,\r\n      refreshInterval: null,\r\n      hoveredMessageId: null,\r\n      deleteMenuId: null,\r\n    };\r\n  },\r\n  computed: {\r\n    token() {\r\n      return localStorage.getItem(\"token\");\r\n    },\r\n  },\r\n  mounted() {\r\n    const user = JSON.parse(localStorage.getItem(\"user\"));\r\n    this.userEmail = user?.email || \"\";\r\n\r\n    this.fetchContacts();\r\n    this.fetchUnreadCount();\r\n\r\n    this.refreshInterval = setInterval(() => {\r\n      if (this.selectedContact) {\r\n        this.fetchMessages();\r\n      }\r\n      this.fetchUnreadCount();\r\n    }, 2000);\r\n  },\r\n  beforeUnmount() {\r\n    if (this.refreshInterval) {\r\n      clearInterval(this.refreshInterval);\r\n    }\r\n  },\r\n  methods: {\r\n    async fetchContacts() {\r\n      try {\r\n        const res = await axios.get(\"/api/messages/list\");\r\n\r\n        if (res.data.success) {\r\n          this.contacts = res.data.data;\r\n        }\r\n      } catch (err) {\r\n        console.error(\"Error fetching contacts:\", err);\r\n      }\r\n    },\r\n    async fetchMessages() {\r\n      if (!this.selectedContact) return;\r\n\r\n      try {\r\n        const res = await axios.get(\r\n          `/api/messages/conversation/${this.selectedContact.email}`\r\n        );\r\n\r\n        if (res.data.success) {\r\n          this.messages = res.data.data;\r\n          this.$nextTick(() => {\r\n            const container = this.$refs.messagesContainer;\r\n            if (container) {\r\n              container.scrollTop = container.scrollHeight;\r\n            }\r\n          });\r\n        }\r\n      } catch (err) {\r\n        console.error(\"Error fetching messages:\", err);\r\n      }\r\n    },\r\n    async sendMessage() {\r\n      if (!this.newMessage.trim() || !this.selectedContact) return;\r\n\r\n      this.sending = true;\r\n      try {\r\n        const res = await axios.post(\"/api/messages/send\", {\r\n          receiverEmail: this.selectedContact.email,\r\n          message: this.newMessage,\r\n        });\r\n\r\n        if (res.status === 201) {\r\n          this.newMessage = \"\";\r\n          await this.fetchMessages();\r\n        }\r\n      } catch (err) {\r\n        console.error(\"Error sending message:\", err);\r\n      } finally {\r\n        this.sending = false;\r\n      }\r\n    },\r\n    selectContact(contact) {\r\n      this.selectedContact = contact;\r\n      this.fetchMessages();\r\n    },\r\n    async fetchUnreadCount() {\r\n      try {\r\n        const res = await axios.get(\"/api/messages/unread-count\");\r\n\r\n        if (res.data.success) {\r\n          this.unreadCount = res.data.unreadCount;\r\n        }\r\n      } catch (err) {\r\n        console.error(\"Error fetching unread count:\", err);\r\n      }\r\n    },\r\n    formatTime(timestamp) {\r\n      const date = new Date(timestamp);\r\n      const hours = String(date.getHours()).padStart(2, \"0\");\r\n      const minutes = String(date.getMinutes()).padStart(2, \"0\");\r\n      return `${hours}:${minutes}`;\r\n    },\r\n    isMessageDeleted(msg) {\r\n      return (\r\n        msg.deletedForEveryone ||\r\n        (msg.deletedBy && msg.deletedBy.includes(this.userEmail))\r\n      );\r\n    },\r\n    showDeleteMenu(messageId) {\r\n      this.deleteMenuId = this.deleteMenuId === messageId ? null : messageId;\r\n    },\r\n    async deleteMessageForMe(messageId) {\r\n      try {\r\n        await axios.delete(`/api/messages/${messageId}`);\r\n        await this.fetchMessages();\r\n        this.hoveredMessageId = null;\r\n      } catch (err) {\r\n        console.error(\"Error deleting me