{"ast":null,"code":"import axios from \"axios\";\nimport Navbar from \"@/components/AppNavbar.vue\";\nimport AppFooter from \"@/components/AppFooter.vue\";\nimport LoginModal from \"@/views/Login.vue\"; // reuse your existing login.vue\n\nexport default {\n  name: \"App\",\n  components: {\n    Navbar,\n    AppFooter,\n    LoginModal\n  },\n  data() {\n    return {\n      showLogin: false\n    };\n  },\n  async created() {\n    const token = localStorage.getItem(\"token\");\n    if (token) {\n      try {\n        // Verify token with backend\n        const res = await axios.get(\"/api/auth/verify\");\n        if (res.data.valid) {\n          // Sync user info just in case\n          localStorage.setItem(\"user\", JSON.stringify(res.data.user));\n        }\n      } catch (err) {\n        console.warn(\"Session verification failed on startup:\", err);\n        // We don't necessarily logout here, let the interceptor handle 401s\n      }\n    }\n  },\n  computed: {\n    isDashboard() {\n      const path = this.$route.path.toLowerCase();\n      return path.startsWith(\"/admin\") || path.startsWith(\"/staff\") || path === \"/user\" || path === \"/user/\";\n    }\n  }\n};","map":{"version":3,"names":["axios","Navbar","AppFooter","LoginModal","name","components","data","showLogin","created","token","localStorage","getItem","res","get","valid","setItem","JSON","stringify","user","err","console","warn","computed","isDashboard","path","$route","toLowerCase","startsWith"],"sources":["C:\\Users\\LENOVO\\Music\\OneDrive\\Pictures\\distribution-agency-project\\frontend\\src\\App.vue"],"sourcesContent":["<template>\r\n  <div id=\"app\">\r\n    <!-- Navbar only visible when NOT on /admin or /staff -->\r\n    <Navbar v-if=\"!isDashboard\" @open-login=\"showLogin = true\" />\r\n\r\n    <!-- Page Content -->\r\n    <router-view />\r\n\r\n    <!-- Public Footer -->\r\n    <AppFooter v-if=\"!isDashboard\" />\r\n\r\n    <!-- Login Modal -->\r\n    <LoginModal v-if=\"showLogin\" @close=\"showLogin = false\" />\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport axios from \"axios\";\r\nimport Navbar from \"@/components/AppNavbar.vue\";\r\nimport AppFooter from \"@/components/AppFooter.vue\";\r\nimport LoginModal from \"@/views/Login.vue\"; // reuse your existing login.vue\r\n\r\nexport default {\r\n  name: \"App\",\r\n  components: { Navbar, AppFooter, LoginModal },\r\n  data() {\r\n    return {\r\n      showLogin: false,\r\n    };\r\n  },\r\n  async created() {\r\n    const token = localStorage.getItem(\"token\");\r\n    if (token) {\r\n      try {\r\n        // Verify token with backend\r\n        const res = await axios.get(\"/api/auth/verify\");\r\n        if (res.data.valid) {\r\n          // Sync user info just in case\r\n          localStorage.setItem(\"user\", JSON.stringify(res.data.user));\r\n        }\r\n      } catch (err) {\r\n        console.warn(\"Session verification failed on startup:\", err);\r\n        // We don't necessarily logout here, let the interceptor handle 401s\r\n      }\r\n    }\r\n  },\r\n  computed: {\r\n    isDashboard() {\r\n      const path = this.$route.path.toLowerCase();\r\n      return (\r\n        path.startsWith(\"/admin\") ||\r\n        path.startsWith(\"/staff\") ||\r\n        path === \"/user\" ||\r\n        path === \"/user/\"\r\n      );\r\n    },\r\n  },\r\n};\r\n</script>\r\n"],"mappings":"AAiBA,OAAOA,KAAI,MAAO,OAAO;AACzB,OAAOC,MAAK,MAAO,4BAA4B;AAC/C,OAAOC,SAAQ,MAAO,4BAA4B;AAClD,OAAOC,UAAS,MAAO,mBAAmB,EAAE;;AAE5C,eAAe;EACbC,IAAI,EAAE,KAAK;EACXC,UAAU,EAAE;IAAEJ,MAAM;IAAEC,SAAS;IAAEC;EAAW,CAAC;EAC7CG,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,SAAS,EAAE;IACb,CAAC;EACH,CAAC;EACD,MAAMC,OAAOA,CAAA,EAAG;IACd,MAAMC,KAAI,GAAIC,YAAY,CAACC,OAAO,CAAC,OAAO,CAAC;IAC3C,IAAIF,KAAK,EAAE;MACT,IAAI;QACF;QACA,MAAMG,GAAE,GAAI,MAAMZ,KAAK,CAACa,GAAG,CAAC,kBAAkB,CAAC;QAC/C,IAAID,GAAG,CAACN,IAAI,CAACQ,KAAK,EAAE;UAClB;UACAJ,YAAY,CAACK,OAAO,CAAC,MAAM,EAAEC,IAAI,CAACC,SAAS,CAACL,GAAG,CAACN,IAAI,CAACY,IAAI,CAAC,CAAC;QAC7D;MACF,EAAE,OAAOC,GAAG,EAAE;QACZC,OAAO,CAACC,IAAI,CAAC,yCAAyC,EAAEF,GAAG,CAAC;QAC5D;MACF;IACF;EACF,CAAC;EACDG,QAAQ,EAAE;IACRC,WAAWA,CAAA,EAAG;MACZ,MAAMC,IAAG,GAAI,IAAI,CAACC,MAAM,CAACD,IAAI,CAACE,WAAW,CAAC,CAAC;MAC3C,OACEF,IAAI,CAACG,UAAU,CAAC,QAAQ,KACxBH,IAAI,CAACG,UAAU,CAAC,QAAQ,KACxBH,IAAG,KAAM,OAAM,IACfA,IAAG,KAAM,QAAO;IAEpB;EACF;AACF,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}