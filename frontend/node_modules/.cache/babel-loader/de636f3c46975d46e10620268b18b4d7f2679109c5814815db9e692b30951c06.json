{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport axios from \"@/utils/axios\";\nexport default {\n  name: \"ResetPassword\",\n  data() {\n    return {\n      password: \"\",\n      confirmPassword: \"\",\n      message: \"\",\n      error: \"\",\n      loading: false\n    };\n  },\n  computed: {\n    token() {\n      return this.$route.query.token || \"\";\n    },\n    email() {\n      return this.$route.query.email || \"\";\n    }\n  },\n  methods: {\n    async handleResetPassword() {\n      this.message = \"\";\n      this.error = \"\";\n      if (!this.token || !this.email) {\n        this.error = \"Invalid or missing reset link details.\";\n        return;\n      }\n      if (!this.password || !this.confirmPassword) {\n        this.error = \"Please fill both password fields.\";\n        return;\n      }\n      if (this.password !== this.confirmPassword) {\n        this.error = \"Passwords do not match.\";\n        return;\n      }\n      try {\n        this.loading = true;\n        const res = await axios.post(\"/api/auth/reset-password\", {\n          token: this.token,\n          email: this.email,\n          password: this.password\n        });\n        this.message = res.data.message || \"Password updated successfully.\";\n        setTimeout(() => {\n          this.$router.push(\"/login\");\n        }, 1500);\n      } catch (err) {\n        this.error = err.response?.data?.msg || \"Error resetting password.\";\n      } finally {\n        this.loading = false;\n      }\n    }\n  }\n};","map":{"version":3,"names":["axios","name","data","password","confirmPassword","message","error","loading","computed","token","$route","query","email","methods","handleResetPassword","res","post","setTimeout","$router","push","err","response","msg"],"sources":["C:\\Users\\LENOVO\\Music\\OneDrive\\Pictures\\distribution-agency-project\\frontend\\src\\views\\ResetPassword.vue"],"sourcesContent":["<template>\r\n  <div class=\"reset-container\">\r\n    <div class=\"reset-box\">\r\n      <h2>Reset Password</h2>\r\n\r\n      <form @submit.prevent=\"handleResetPassword\" novalidate>\r\n        <input\r\n          type=\"password\"\r\n          v-model.trim=\"password\"\r\n          placeholder=\"New password\"\r\n          required\r\n          autocomplete=\"new-password\"\r\n        />\r\n        <input\r\n          type=\"password\"\r\n          v-model.trim=\"confirmPassword\"\r\n          placeholder=\"Confirm new password\"\r\n          required\r\n          autocomplete=\"new-password\"\r\n        />\r\n\r\n        <button type=\"submit\" :disabled=\"loading\">\r\n          <span v-if=\"loading\">Updating...</span>\r\n          <span v-else>Reset Password</span>\r\n        </button>\r\n      </form>\r\n\r\n      <p v-if=\"message\" class=\"success\">{{ message }}</p>\r\n      <p v-if=\"error\" class=\"error\">{{ error }}</p>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport axios from \"@/utils/axios\";\r\n\r\nexport default {\r\n  name: \"ResetPassword\",\r\n  data() {\r\n    return {\r\n      password: \"\",\r\n      confirmPassword: \"\",\r\n      message: \"\",\r\n      error: \"\",\r\n      loading: false,\r\n    };\r\n  },\r\n  computed: {\r\n    token() {\r\n      return this.$route.query.token || \"\";\r\n    },\r\n    email() {\r\n      return this.$route.query.email || \"\";\r\n    },\r\n  },\r\n  methods: {\r\n    async handleResetPassword() {\r\n      this.message = \"\";\r\n      this.error = \"\";\r\n\r\n      if (!this.token || !this.email) {\r\n        this.error = \"Invalid or missing reset link details.\";\r\n        return;\r\n      }\r\n\r\n      if (!this.password || !this.confirmPassword) {\r\n        this.error = \"Please fill both password fields.\";\r\n        return;\r\n      }\r\n\r\n      if (this.password !== this.confirmPassword) {\r\n        this.error = \"Passwords do not match.\";\r\n        return;\r\n      }\r\n\r\n      try {\r\n        this.loading = true;\r\n        const res = await axios.post(\"/api/auth/reset-password\", {\r\n          token: this.token,\r\n          email: this.email,\r\n          password: this.password,\r\n        });\r\n        this.message = res.data.message || \"Password updated successfully.\";\r\n        setTimeout(() => {\r\n          this.$router.push(\"/login\");\r\n        }, 1500);\r\n      } catch (err) {\r\n        this.error = err.response?.data?.msg || \"Error resetting password.\";\r\n      } finally {\r\n        this.loading = false;\r\n      }\r\n    },\r\n  },\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n.reset-container {\r\n  display: flex;\r\n  justify-content: center;\r\n  align-items: center;\r\n  height: 100vh;\r\n  background: rgba(0, 0, 0, 0.05);\r\n}\r\n\r\n.reset-box {\r\n  background: #fff;\r\n  padding: 2rem;\r\n  border-radius: 10px;\r\n  max-width: 380px;\r\n  width: 100%;\r\n  box-shadow: 0 6px 20px rgba(0, 0, 0, 0.08);\r\n}\r\n\r\ninput {\r\n  width: 100%;\r\n  padding: 0.6rem;\r\n  margin-bottom: 1rem;\r\n  border-radius: 6px;\r\n  border: 1px solid #ddd;\r\n  box-sizing: border-box;\r\n}\r\n\r\nbutton {\r\n  width: 100%;\r\n  padding: 0.6rem;\r\n  border-radius: 6px;\r\n  border: none;\r\n  background: #1e3a8a;\r\n  color: white;\r\n  cursor: pointer;\r\n}\r\n\r\n.success {\r\n  color: green;\r\n  font-size: 0.9rem;\r\n}\r\n\r\n.error {\r\n  color: red;\r\n  font-size: 0.9rem;\r\n}\r\n</style>\r\n"],"mappings":";AAkCA,OAAOA,KAAI,MAAO,eAAe;AAEjC,eAAe;EACbC,IAAI,EAAE,eAAe;EACrBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,QAAQ,EAAE,EAAE;MACZC,eAAe,EAAE,EAAE;MACnBC,OAAO,EAAE,EAAE;MACXC,KAAK,EAAE,EAAE;MACTC,OAAO,EAAE;IACX,CAAC;EACH,CAAC;EACDC,QAAQ,EAAE;IACRC,KAAKA,CAAA,EAAG;MACN,OAAO,IAAI,CAACC,MAAM,CAACC,KAAK,CAACF,KAAI,IAAK,EAAE;IACtC,CAAC;IACDG,KAAKA,CAAA,EAAG;MACN,OAAO,IAAI,CAACF,MAAM,CAACC,KAAK,CAACC,KAAI,IAAK,EAAE;IACtC;EACF,CAAC;EACDC,OAAO,EAAE;IACP,MAAMC,mBAAmBA,CAAA,EAAG;MAC1B,IAAI,CAACT,OAAM,GAAI,EAAE;MACjB,IAAI,CAACC,KAAI,GAAI,EAAE;MAEf,IAAI,CAAC,IAAI,CAACG,KAAI,IAAK,CA