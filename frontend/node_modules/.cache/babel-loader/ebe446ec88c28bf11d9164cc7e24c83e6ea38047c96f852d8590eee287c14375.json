{"ast":null,"code":"import \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.for-each.js\";\nexport default {\n  name: \"AboutPage\",\n  data() {\n    return {\n      email: \"\"\n    };\n  },\n  methods: {\n    subscribe() {\n      alert(\"Thank you for subscribing!\");\n      this.email = \"\";\n    }\n  },\n  directives: {\n    animateOnScroll: {\n      mounted(el) {\n        const observer = new IntersectionObserver(entries => {\n          entries.forEach(entry => {\n            if (entry.isIntersecting) {\n              el.classList.add('is-visible');\n              observer.unobserve(el);\n            }\n          });\n        }, {\n          threshold: 0.1\n        });\n        observer.observe(el);\n      }\n    }\n  }\n};","map":{"version":3,"names":["name","data","email","methods","subscribe","alert","directives","animateOnScroll","mounted","el","observer","IntersectionObserver","entries","forEach","entry","isIntersecting","classList","add","unobserve","threshold","observe"],"sources":["C:\\Users\\LENOVO\\Music\\OneDrive\\Pictures\\distribution-agency-project\\frontend\\src\\views\\About.vue"],"sourcesContent":["<template>\r\n  <div class=\"about-page\">\r\n    <!-- Header Section -->\r\n    <section class=\"about-header\">\r\n      <div class=\"header-overlay\"></div>\r\n      <h1 class=\"page-title\">About Us</h1>\r\n    </section>\r\n\r\n    <!-- Our Story Section -->\r\n    <section class=\"our-story container\">\r\n      <div class=\"story-grid\">\r\n        <div class=\"story-image\" v-animate-on-scroll>\r\n          <img src=\"https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?auto=format&fit=crop&q=80&w=800\" alt=\"Warehouse Distribution\" class=\"chef-img\" />\r\n        </div>\r\n        <div class=\"story-content\" v-animate-on-scroll>\r\n          <h2 class=\"section-title\">Our Heritage</h2>\r\n          <p class=\"story-text\">\r\n            Cochin Distributors is a well-established merchant distribution agency located in Kattappana, Idukki. With over 13 years of experience, we have built a strong reputation for reliability, efficiency, and quality service across the Idukki region.\r\n          </p>\r\n          <p class=\"story-text\">\r\n            Founded with the vision of delivering quality packaged food products to retailers efficiently, we have grown into a trusted name in the local distribution sector, ensuring timely supply to shops, supermarkets, and merchants throughout the district.\r\n          </p>\r\n          <div class=\"founder-info\">\r\n            <h4 class=\"founder-name\">Serving Idukki Since 2011</h4>\r\n            <p class=\"founder-role\">Quality Service, Timely Delivery</p>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </section>\r\n\r\n    <!-- Distribution Features Section -->\r\n    <section class=\"distribution-details container\">\r\n      <div class=\"details-grid\">\r\n        <div class=\"detail-card\" v-animate-on-scroll>\r\n          <div class=\"detail-icon\">🛍️</div>\r\n          <h3>Products Distributed</h3>\r\n          <ul>\r\n            <li>🍪 Biscuits (Parle-G, 20-20, etc.)</li>\r\n            <li>🍿 Snacks and Packaged Chips</li>\r\n            <li>🥤 Cool Drinks and Beverages</li>\r\n            <li>🥨 Essential Packaged Foods</li>\r\n          </ul>\r\n        </div>\r\n        <div class=\"detail-card\" v-animate-on-scroll>\r\n          <div class=\"detail-icon\">🚚</div>\r\n          <h3>Distribution Network</h3>\r\n          <p>Our self-managed delivery system ensures timely transportation and safe product handling across Kattappana and surrounding hilly regions.</p>\r\n        </div>\r\n        <div class=\"detail-card\" v-animate-on-scroll>\r\n          <div class=\"detail-icon\">👥</div>\r\n          <h3>Our Workforce</h3>\r\n          <p>A dedicated team of 10 members including sales representatives, delivery personnel, and warehouse handlers ensuring smooth operations.</p>\r\n        </div>\r\n      </div>\r\n    </section>\r\n\r\n    <!-- Newsletter Section -->\r\n    <section class=\"newsletter-section\">\r\n      <div class=\"container\">\r\n        <h2 class=\"newsletter-title\">Subscribe To Our Newsletter</h2>\r\n        <form class=\"newsletter-form\" @submit.prevent=\"subscribe\">\r\n          <input type=\"email\" placeholder=\"your email address\" required v-model=\"email\" />\r\n          <button type=\"submit\" class=\"btn-subscribe\">Subscribe</button>\r\n        </form>\r\n      </div>\r\n    </section>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"AboutPage\",\r\n  data() {\r\n    return {\r\n      email: \"\"\r\n    };\r\n  },\r\n  methods: {\r\n    subscribe() {\r\n      alert(\"Thank you for subscribing!\");\r\n      this.email = \"\";\r\n    }\r\n  },\r\n  directives: {\r\n    animateOnScroll: {\r\n      mounted(el) {\r\n        const observer = new IntersectionObserver((entries) => {\r\n          entries.forEach(entry => {\r\n            if (entry.isIntersecting) {\r\n              el.classList.add('is-visible');\r\n              observer.unobserve(el);\r\n            }\r\n          });\r\n        }, { threshold: 0.1 });\r\n        observer.observe(el);\r\n      }\r\n    }\r\n  }\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n.about-page {\r\n  font-family: 'Plus Jakarta Sans', sans-serif;\r\n  color: #5d4037;\r\n  background-color: #ffffff;\r\n  padding-top: 80px;\r\n}\r\n\r\n.container {\r\n  max-width: 1200px;\r\n  margin: 0 auto;\r\n  padding: 0 2rem;\r\n}\r\n\r\n/* --- Header --- */\r\n.about-header {\r\n  height: 40vh;\r\n  position: relative;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  background: url('https://images.unsplash.com/photo-1517433670267-08bbd4be890f?auto=format&fit=crop&q=80&w=1200') center/cover no-repeat;\r\n  margin-top: 80px;\r\n}\r\n\r\n.header-overlay {\r\n  position: absolute;\r\n  inset: 0;\r\n  background: rgba(62, 39, 35, 0.4);\r\n}\r\n\r\n.page-title {\r\n  position: relative;\r\n  z-index: 1;\r\n  font-family: 'Dancing Script', cursive;\r\n  font-size: 4.5rem;\r\n  color: white;\r\n  font-weight: 700;\r\n  text-shadow: 0 4px 10px rgba(0,0,0,0.3);\r\n}\r\n\r\n/* --- Our Story --- */\r\n.our-story {\r\n  padding: 8rem 0;\r\n}\r\n\r\n.story-grid {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 5rem;\r\n}\r\n\r\n.story-image {\r\n  flex: 1;\r\n  opacity: 0;\r\n  transform: translateX(-30px);\r\n  transition: all 0.8s ease;\r\n}\r\n\r\n.story-image.is-visible {\r\n  opacity: 1;\r\n  transform: translateX(0);\r\n}\r\n\r\n.chef-img {\r\n  width: 100%;\r\n  border-radius: 15px;\r\n  box-shadow: 20px 20px 50px rgba(0,0,0,0.05);\r\n}\r\n\r\n.story-content {\r\n  flex: 1.2;\r\n  opacity: 0;\r\n  transform: translateX(30px);\r\n  transition: all 0.8s ease 0.2s;\r\n}\r\n\r\n.story-content.is-visible {\r\n  opacity: 1;\r\n  transform: translateX(0);\r\n}\r\n\r\n.section-title {\r\n  font-family: 'Dancing Script', cursive;\r\n  font-size: 3.5rem;\r\n  margin-bottom: 2rem;\r\n  color: #3e2723;\r\n}\r\n\r\n.story-text {\r\n  font-size: 1.05rem;\r\n  line-height: 1.8;\r\n  color: #8d6e63;\r\n  margin-bottom: 2rem;\r\n}\r\n\r\n.founder-info {\r\n  margin-top: 3rem;\r\n}\r\n\r\n.founder-name {\r\n  font-size: 1.4rem;\r\n  font-weight: 700;\r\n  color: #3e2723;\r\n  margin-bottom: 0.2rem;\r\n}\r\n\r\n.founder-role {\r\n  color: #efa962;\r\n  font-weight: 600;\r\n  font-size: 0.9rem;\r\n}\r\n\r\n/* --- Distribution Details --- */\r\n.distribution-details {\r\n  padding-bottom: 8rem;\r\n}\r\n\r\n.details-grid {\r\n  display: grid;\r\n  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));\r\n  gap: 2rem;\r\n}\r\n\r\n.detail-card {\r\n  background: #fff5e6;\r\n  padding: 3rem 2rem;\r\n  border-radius: 15px;\r\n  text-align: center;\r\n  transition: transform 0.3s ease;\r\n  opacity: 0;\r\n  transform: translateY(20px);\r\n}\r\n\r\n.detail-card.is-visible {\r\n  opacity: 1;\r\n  transform: translateY(0);\r\n}\r\n\r\n.detail-card:hover {\r\n  transform: translateY(-10px);\r\n}\r\n\r\n.detail-icon {\r\n  font-size: 3rem;\r\n  margin-bottom: 1.5rem;\r\n}\r\n\r\n.detail-card h3 {\r\n  font-size: 1.5rem;\r\n  color: #3e2723;\r\n  margin-bottom: 1rem;\r\n}\r\n\r\n.detail-card ul {\r\n  list-style: none;\r\n  padding: 0;\r\n  color: #8d6e63;\r\n  line-height: 2;\r\n}\r\n\r\n.detail-card p {\r\n  color: #8d6e63;\r\n  line-height: 1.6;\r\n}\r\n\r\n/* --- Newsletter --- */\r\n.newsletter-section {\r\n  background-color: #3e2723;\r\n  padding: 6rem 0;\r\n  text-align: center;\r\n  color: white;\r\n}\r\n\r\n.newsletter-title {\r\n  font-family: 'Dancing Script', cursive;\r\n  font-size: 3.2rem;\r\n  margin-bottom: 3.5rem;\r\n}\r\n\r\n.newsletter-form {\r\n  display: flex;\r\n  justify-content: center;\r\n  gap: 1rem;\r\n  max-width: 600px;\r\n  margin: 0 auto;\r\n}\r\n\r\n.newsletter-form input {\r\n  flex: 1;\r\n  padding: 1.1rem 1.5rem;\r\n  border-radius: 4px;\r\n  border: 1px solid #5d4037;\r\n  background: #2b1b17;\r\n  color: white;\r\n  font-size: 1rem;\r\n}\r\n\r\n.btn-subscribe {\r\n  background-color: #efa962;\r\n  color: white;\r\n  border: none;\r\n  padding: 1.1rem 2.5rem;\r\n  border-radius: 4px;\r\n  font-weight: 700;\r\n  cursor: pointer;\r\n  transition: all 0.3s ease;\r\n  text-transform: uppercase;\r\n  letter-spacing: 1px;\r\n}\r\n\r\n.btn-subscribe:hover {\r\n  background-color: #e69642;\r\n  transform: translateY(-2px);\r\n}\r\n\r\n@media (max-width: 992px) {\r\n  .story-grid {\r\n    flex-direction: column;\r\n    text-align: center;\r\n  }\r\n  .story-content { transform: translateX(0); }\r\n  .page-title { font-size: 3.5rem; }\r\n  .testimonial-header { font-size: 2.8rem; }\r\n}\r\n\r\n@media (max-width: 768px) {\r\n  .newsletter-form {\r\n    flex-direction: column;\r\n  }\r\n}\r\n</style>\r\n"],"mappings":";;AAsEA,eAAe;EACbA,IAAI,EAAE,WAAW;EACjBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,KAAK,EAAE;IACT,CAAC;EACH,CAAC;EACDC,OAAO,EAAE;IACPC,SAASA,CAAA,EAAG;MACVC,KAAK