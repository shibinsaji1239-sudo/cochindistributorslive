{"ast":null,"code":"import axios from \"@/utils/axios\";\nexport default {\n  name: \"ForgotPassword\",\n  data() {\n    return {\n      email: \"\",\n      message: \"\",\n      error: \"\",\n      loading: false\n    };\n  },\n  methods: {\n    async handleForgotPassword() {\n      this.message = \"\";\n      this.error = \"\";\n      if (!this.email) {\n        this.error = \"Please enter your email.\";\n        return;\n      }\n      try {\n        this.loading = true;\n        const res = await axios.post(\"/api/auth/forgot-password\", {\n          email: this.email\n        });\n        this.message = res.data.message || \"If registered, a reset link has been sent.\";\n      } catch (err) {\n        this.error = err.response?.data?.msg || \"Error sending reset link.\";\n      } finally {\n        this.loading = false;\n      }\n    }\n  }\n};","map":{"version":3,"names":["axios","name","data","email","message","error","loading","methods","handleForgotPassword","res","post","err","response","msg"],"sources":["C:\\Users\\LENOVO\\Music\\OneDrive\\Pictures\\distribution-agency-project\\frontend\\src\\views\\ForgotPassword.vue"],"sourcesContent":["<template>\r\n  <div class=\"forgot-container\">\r\n    <div class=\"forgot-box\">\r\n      <h2>Forgot Password</h2>\r\n      <p>Enter your email to receive a password reset link.</p>\r\n\r\n      <form @submit.prevent=\"handleForgotPassword\" novalidate>\r\n        <input\r\n          type=\"email\"\r\n          v-model.trim=\"email\"\r\n          placeholder=\"Enter your email\"\r\n          required\r\n          autocomplete=\"email\"\r\n        />\r\n        <button type=\"submit\" :disabled=\"loading\">\r\n          <span v-if=\"loading\">Sending...</span>\r\n          <span v-else>Send Reset Link</span>\r\n        </button>\r\n      </form>\r\n\r\n      <p v-if=\"message\" class=\"success\">{{ message }}</p>\r\n      <p v-if=\"error\" class=\"error\">{{ error }}</p>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport axios from \"@/utils/axios\";\r\n\r\nexport default {\r\n  name: \"ForgotPassword\",\r\n  data() {\r\n    return {\r\n      email: \"\",\r\n      message: \"\",\r\n      error: \"\",\r\n      loading: false,\r\n    };\r\n  },\r\n  methods: {\r\n    async handleForgotPassword() {\r\n      this.message = \"\";\r\n      this.error = \"\";\r\n\r\n      if (!this.email) {\r\n        this.error = \"Please enter your email.\";\r\n        return;\r\n      }\r\n\r\n      try {\r\n        this.loading = true;\r\n        const res = await axios.post(\"/api/auth/forgot-password\", {\r\n          email: this.email,\r\n        });\r\n        this.message =\r\n          res.data.message || \"If registered, a reset link has been sent.\";\r\n      } catch (err) {\r\n        this.error = err.response?.data?.msg || \"Error sending reset link.\";\r\n      } finally {\r\n        this.loading = false;\r\n      }\r\n    },\r\n  },\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n.forgot-container {\r\n  display: flex;\r\n  justify-content: center;\r\n  align-items: center;\r\n  height: 100vh;\r\n  background: rgba(0, 0, 0, 0.05);\r\n}\r\n\r\n.forgot-box {\r\n  background: #fff;\r\n  padding: 2rem;\r\n  border-radius: 10px;\r\n  max-width: 380px;\r\n  width: 100%;\r\n  box-shadow: 0 6px 20px rgba(0, 0, 0, 0.08);\r\n}\r\n\r\ninput {\r\n  width: 100%;\r\n  padding: 0.6rem;\r\n  margin-bottom: 1rem;\r\n  border-radius: 6px;\r\n  border: 1px solid #ddd;\r\n  box-sizing: border-box;\r\n}\r\n\r\nbutton {\r\n  width: 100%;\r\n  padding: 0.6rem;\r\n  border-radius: 6px;\r\n  border: none;\r\n  background: #1e3a8a;\r\n  color: white;\r\n  cursor: pointer;\r\n}\r\n\r\n.success {\r\n  color: green;\r\n  font-size: 0.9rem;\r\n}\r\n\r\n.error {\r\n  color: red;\r\n  font-size: 0.9rem;\r\n}\r\n</style>\r\n"],"mappings":"AA2BA,OAAOA,KAAI,MAAO,eAAe;AAEjC,eAAe;EACbC,IAAI,EAAE,gBAAgB;EACtBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,KAAK,EAAE,EAAE;MACTC,OAAO,EAAE,EAAE;MACXC,KAAK,EAAE,EAAE;MACTC,OAAO,EAAE;