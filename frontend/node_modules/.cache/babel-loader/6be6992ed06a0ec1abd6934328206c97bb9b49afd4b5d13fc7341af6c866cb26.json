{"ast":null,"code":"import \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.find.js\";\nimport axios from \"@/utils/axios\";\nimport socket from \"@/socket\";\nexport default {\n  name: \"AdminOrders\",\n  data() {\n    return {\n      orders: [],\n      loading: false\n    };\n  },\n  mounted() {\n    this.fetchOrders();\n\n    // Socket listeners for real-time updates\n    socket.on(\"orderPlaced\", () => {\n      this.fetchOrders();\n    });\n    socket.on(\"orderStatusUpdate\", data => {\n      // Update the specific order status\n      const order = this.orders.find(o => o._id === data.orderId);\n      if (order) {\n        order.status = data.status;\n      }\n    });\n  },\n  beforeUnmount() {\n    // Remove socket listeners\n    socket.off(\"orderPlaced\");\n    socket.off(\"orderStatusUpdate\");\n  },\n  methods: {\n    async fetchOrders() {\n      this.loading = true;\n      try {\n        const res = await axios.get(\"/api/orders/admin/all-orders\");\n        this.orders = res.data;\n      } catch (err) {\n        console.error(\"Error fetching admin orders:\", err);\n      } finally {\n        this.loading = false;\n      }\n    },\n    async updateStatus(orderId, newStatus) {\n      try {\n        await axios.patch(`/api/orders/admin/orders/${orderId}/status`, {\n          status: newStatus\n        });\n        alert(\"Order status updated successfully\");\n      } catch (err) {\n        console.error(\"Error updating order status:\", err);\n        alert(\"Failed to update status\");\n      }\n    },\n    formatDate(date) {\n      return new Date(date).toLocaleDateString(\"en-IN\", {\n        day: \"numeric\",\n        month: \"short\",\n        year: \"numeric\"\n      });\n    }\n  }\n};","map":{"version":3,"names":["axios","socket","name","data","orders","loading","mounted","fetchOrders","on","order","find","o","_id","orderId","status","beforeUnmount","off","methods","res","get","err","console","error","updateStatus","newStatus","patch","alert","formatDate","date","Date","toLocaleDateString","day","month","year"],"sources":["C:\\Users\\LENOVO\\Music\\OneDrive\\Pictures\\distribution-agency-project\\frontend\\src\\views\\AdminOrders.vue"],"sourcesContent":["<template>\r\n  <div class=\"admin-orders-container\">\r\n    <div class=\"section-card\">\r\n      <div class=\"section-header\">\r\n        <h3>Order Management</h3>\r\n        <button class=\"btn-refresh\" @click=\"fetchOrders\">Refresh</button>\r\n      </div>\r\n\r\n      <div v-if=\"loading\" class=\"loading-state\">\r\n        <div class=\"spinner\"></div>\r\n        <p>Loading orders...</p>\r\n      </div>\r\n\r\n      <div v-else-if=\"orders.length === 0\" class=\"empty-state\">\r\n        <p>No orders found.</p>\r\n      </div>\r\n\r\n      <div v-else class=\"orders-table-wrapper\">\r\n        <table class=\"data-table\">\r\n          <thead>\r\n            <tr>\r\n              <th>Order ID</th>\r\n              <th>User Details</th>\r\n              <th>Products</th>\r\n              <th>Total Amount</th>\r\n              <th>Status</th>\r\n              <th>Date</th>\r\n              <th>Actions</th>\r\n            </tr>\r\n          </thead>\r\n          <tbody>\r\n            <tr v-for=\"order in orders\" :key=\"order._id\">\r\n              <td>#{{ order._id.slice(-6) }}</td>\r\n              <td>\r\n                <div class=\"user-info\">\r\n                  <strong>{{ order.user?.name || \"N/A\" }}</strong>\r\n                  <span>Merchant: {{ order.user?.storeName || \"N/A\" }}</span>\r\n                  <small>Phone: {{ order.user?.phone || \"N/A\" }}</small>\r\n                  <small\r\n                    >Address: {{ order.user?.storeAddress || \"N/A\" }}</small\r\n                  >\r\n                  <small>Pincode: {{ order.user?.pincode || \"N/A\" }}</small>\r\n                </div>\r\n              </td>\r\n              <td>\r\n                <div class=\"products-list\">\r\n                  <div\r\n                    v-for=\"item in order.items\"\r\n                    :key=\"item._id\"\r\n                    class=\"product-item\"\r\n                  >\r\n                    {{ item.product?.name || \"N/A\" }} (x{{ item.quantity }})\r\n                  </div>\r\n                </div>\r\n              </td>\r\n              <td>₹{{ order.totalAmount }}</td>\r\n              <td>\r\n                <span class=\"status-badge\" :class=\"order.status\">{{\r\n                  order.status\r\n                }}</span>\r\n              </td>\r\n              <td>{{ formatDate(order.createdAt) }}</td>\r\n              <td>\r\n                <div class=\"actions\">\r\n                  <select\r\n                    v-model=\"order.status\"\r\n                    @change=\"updateStatus(order._id, order.status)\"\r\n                    class=\"status-select\"\r\n                  >\r\n                    <option value=\"ordered\">Ordered</option>\r\n                    <option value=\"accepted\">Accepted</option>\r\n                    <option value=\"shipped\">Shipped</option>\r\n                    <option value=\"delivered\">Delivered</option>\r\n                    <option value=\"cancelled\">Cancelled</option>\r\n                  </select>\r\n                </div>\r\n              </td>\r\n            </tr>\r\n          </tbody>\r\n        </table>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport axios from \"@/utils/axios\";\r\nimport socket from \"@/socket\";\r\n\r\nexport default {\r\n  name: \"AdminOrders\",\r\n  data() {\r\n    return {\r\n      orders: [],\r\n      loading: false,\r\n    };\r\n  },\r\n  mounted() {\r\n    this.fetchOrders();\r\n\r\n    // Socket listeners for real-time updates\r\n    socket.on(\"orderPlaced\", () => {\r\n      this.fetchOrders();\r\n    });\r\n\r\n    socket.on(\"orderStatusUpdate\", (data) => {\r\n      // Update the specific order status\r\n      const order = this.orders.find((o) => o._id === data.orderId);\r\n      if (order) {\r\n        order.status = data.status;\r\n      }\r\n    });\r\n  },\r\n  beforeUnmount() {\r\n    // Remove socket listeners\r\n    socket.off(\"orderPlaced\");\r\n    socket.off(\"orderStatusUpdate\");\r\n  },\r\n  methods: {\r\n    async fetchOrders() {\r\n      this.loading = true;\r\n      try {\r\n        const res = await axios.get(\"/api/orders/admin/all-orders\");\r\n        this.orders = res.data;\r\n      } catch (err) {\r\n        console.error(\"Error fetching admin orders:\", err);\r\n      } finally {\r\n        this.loading = false;\r\n      }\r\n    },\r\n    async updateStatus(orderId, newStatus) {\r\n      try {\r\n        await axios.patch(`/api/orders/admin/orders/${orderId}/status`, {\r\n          status: newStatus,\r\n        });\r\n        alert(\"Order status updated successfully\");\r\n      } catch (err) {\r\n        console.error(\"Error updating order status:\", err);\r\n        alert(\"Failed to update status\");\r\n      }\r\n    },\r\n    formatDate(date) {\r\n      return new Date(date).toLocaleDateString(\"en-IN\", {\r\n        day: \"numeric\",\r\n        month: \"short\",\r\n        year: \"numeric\",\r\n      });\r\n    },\r\n  },\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n.admin-orders-container {\r\n  padding: 15px;\r\n}\r\n\r\n.orders-table-wrapper {\r\n  overflow-x: auto;\r\n  -webkit-overflow-scrolling: touch;\r\n  border: 1px solid #eee;\r\n  border-radius: 8px;\r\n  background: white;\r\n}\r\n\r\n.data-table {\r\n  width: 100%;\r\n  border-collapse: collapse;\r\n  min-width: 1000px;\r\n}\r\n\r\n.user-info {\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: 2px;\r\n}\r\n\r\n.user-info strong {\r\n  color: #333;\r\n}\r\n\r\n.user-info span {\r\n  font-size: 0.85rem;\r\n  color: #666;\r\n}\r\n\r\n.user-info small {\r\n  font-size: 0.75rem;\r\n  color: #888;\r\n}\r\n\r\n.products-list {\r\n  max-height: 100px;\r\n  overflow-y: auto;\r\n}\r\n\r\n.product-item {\r\n  font-size: 0.85rem;\r\n  margin-bottom: 2px;\r\n}\r\n\r\n.status-badge {\r\n  padding: 4px 8px;\r\n  border-radius: 12px;\r\n  font-size: 0.75rem;\r\n  font-weight: 600;\r\n  text-transform: uppercase;\r\n}\r\n\r\n.status-badge.ordered {\r\n  background: #e3f2fd;\r\n  color: #1976d2;\r\n}\r\n.status-badge.accepted {\r\n  background: #f3e5f5;\r\n  color: #7b1fa2;\r\n}\r\n.status-badge.shipped {\r\n  background: #fff3e0;\r\n  color: #f57c00;\r\n}\r\n.status-badge.delivered {\r\n  background: #e8f5e9;\r\n  color: #388e3c;\r\n}\r\n.status-badge.cancelled {\r\n  background: #ffebee;\r\n  color: #d32f2f;\r\n}\r\n\r\n.status-select {\r\n  padding: 4px 8px;\r\n  border-radius: 4px;\r\n  border: 1px solid #ddd;\r\n  font-size: 0.85rem;\r\n}\r\n\r\n.loading-state,\r\n.empty-state {\r\n  text-align: center;\r\n  padding: 40px;\r\n  color: #666;\r\n}\r\n\r\n.spinner {\r\n  border: 3px solid #f3f3f3;\r\n  border-top: 3px solid #3498db;\r\n  border-radius: 50%;\r\n  width: 30px;\r\n  height: 30px;\r\n  animation: spin 1s linear infinite;\r\n  margin: 0 auto 10px;\r\n}\r\n\r\n@keyframes spin {\r\n  0% {\r\n    transform: rotate(0deg);\r\n  }\r\n  100% {\r\n    transform: rotate(360deg);\r\n  }\r\n}\r\n\r\n.btn-refresh {\r\n  background: #3498db;\r\n  color: white;\r\n  border: none;\r\n  padding: 6px 12px;\r\n  border-radius: 4px;\r\n  cursor: pointer;\r\n}\r\n\r\n.btn-refresh:hover {\r\n  background: #2980b9;\r\n}\r\n</style>\r\n"],"mappings":";;AAsFA,OAAOA,KAAI,MAAO,eAAe;AACjC,OAAOC,MAAK,MAAO,UAAU;AAE7B,eAAe;EACbC,IAAI,EAAE,aAAa;EACnBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,MAAM,EAAE,EAAE;MACVC,OAAO,EAAE;IACX,CAAC;EACH,CAAC;EACDC,OAAOA,CAAA,EAAG;IACR,IAAI,CAACC,WAAW,CAAC,CAAC;;IAElB;IACAN,MAAM,CAACO,EAAE,CAAC,aAAa,EAAE,MAAM;MAC7B,IAAI,CAACD,WAAW,CAAC,CAAC;IACpB,CAAC,CAAC;IAEFN,MAAM,CAACO,EAAE,CAAC,mBAAmB,EAAGL,IAAI,IAAK;MACvC;MACA,MAAMM,KAAI,GAAI,IAAI,CAACL,MAAM,CAACM,IAAI,CAAEC,CAAC,IAAKA,CAAC,CAACC,GAAE,KAAMT,IAAI,CAACU,OAAO,CAAC;MAC7D,IAAIJ,KAAK,EAAE;QACTA,KAAK,CAACK,MAAK,GAAIX,IAAI,CAACW,MAAM;MAC5B;IACF,CAAC,CAAC;EACJ,CAAC;EACDC,aAAaA,CAAA,EAAG;IACd;IACAd,MAAM,CAACe,GAAG,CAAC,aAAa,CAAC;IACzBf,MAAM,CAACe,GAAG,CAAC,mBAAmB,CAAC;EACjC,CAAC;EACDC,OAAO,EAAE;IACP,MAAMV,WAAWA,CAAA,EAAG;MAClB,IAAI,CAACF,OAAM,GAAI,IAAI;MACnB,IAAI;QACF,MAAMa,GAAE,GAAI,MAAMlB,KAAK,CAACmB,GAAG,CAAC,8BAA8B,CAAC;QAC3D,IAAI,CAACf,MAAK,GAAIc,GAAG,CAACf,IAAI;MACxB,EAAE,OAAOiB,GAAG,EAAE;QACZC,OAAO,CAACC,KAAK,CAAC,8BAA8B,EAAEF,GAAG,CAAC;MACpD,UAAU;QACR,IAAI,CAACf,OAAM,GAAI,KAAK;MACtB;IACF,CAAC;IACD,MAAMkB,YAAYA,CAACV,OAAO,EAAEW,SAAS,EAAE;MACrC,IAAI;QACF,MAAMxB,KAAK,CAACyB,KAAK,CAAC,4BAA4BZ,OAAO,SAAS,EAAE;UAC9DC,MAAM,EAAEU;QACV,CAAC,CAAC;QACFE,KAAK,CAAC,mCAAmC,CAAC;MAC5C,EAAE,OAAON,GAAG,EAAE;QACZC,OAAO,CAACC,KAAK,CAAC,8BAA8B,EAAEF,GAAG,CAAC;QAClDM,KAAK,CAAC,yBAAyB,CAAC;MAClC;IACF,CAAC;IACDC,UAAUA,CAACC,IAAI,EAAE;MACf,OAAO,IAAIC,IAAI,CAACD,IAAI,CAAC,CAACE,kBAAkB,CAAC,OAAO,EAAE;QAChDC,GAAG,EAAE,SAAS;QACdC,KAAK,EAAE,OAAO;QACdC,IAAI,EAAE;MACR,CAAC,CAAC;IACJ;EACF;AACF,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}