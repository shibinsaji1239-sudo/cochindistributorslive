{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport axios from \"@/utils/axios\";\nimport \"@/assets/styles/Login.css\";\nexport default {\n  name: \"LoginPage\",\n  data() {\n    return {\n      isSignup: false,\n      email: \"\",\n      password: \"\",\n      isFilled: false,\n      emailError: \"\",\n      passwordError: \"\",\n      loading: false\n    };\n  },\n  computed: {\n    formTitle() {\n      return this.isSignup ? \"Sign Up\" : \"Login\";\n    },\n    toggleText() {\n      return this.isSignup ? \"Already have an account?\" : \"Don’t have an account?\";\n    },\n    toggleLinkText() {\n      return this.isSignup ? \"Login\" : \"Create an account\";\n    }\n  },\n  methods: {\n    toggleMode() {\n      this.isSignup = !this.isSignup;\n      this.resetForm();\n    },\n    loginWithGoogle() {\n      const apiUrl = process.env.VUE_APP_API_URL || window.location.origin;\n      window.location.href = `${apiUrl}/api/auth/google`;\n    },\n    resetForm() {\n      this.email = \"\";\n      this.password = \"\";\n      this.isFilled = false;\n      this.emailError = \"\";\n      this.passwordError = \"\";\n    },\n    checkFilled() {\n      this.isFilled = this.isSignup ? this.email.trim() !== \"\" : this.email.trim() !== \"\" && this.password.trim() !== \"\";\n    },\n    validateEmail(email) {\n      const emailRegex = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/;\n      return emailRegex.test(email);\n    },\n    async handleSubmit() {\n      this.emailError = \"\";\n      this.passwordError = \"\";\n      if (!this.validateEmail(this.email)) {\n        this.emailError = \"Please enter a valid email address.\";\n        return;\n      }\n      this.loading = true;\n      try {\n        if (this.isSignup) {\n          // Signup\n          const {\n            data\n          } = await axios.post(`/api/auth/register-email`, {\n            email: this.email\n          });\n          alert(data.msg || \"A password setup link has been sent to your email.\");\n          this.toggleMode();\n        } else {\n          // Login\n          const {\n            data\n          } = await axios.post(`/api/auth/login`, {\n            email: this.email,\n            password: this.password\n          });\n\n          // Save token and user info\n          localStorage.setItem(\"token\", data.token);\n          localStorage.setItem(\"user\", JSON.stringify(data.user));\n\n          // Dynamic login message\n          alert(`${data.user.role.toUpperCase()} login successful!`);\n\n          // Redirect based on role\n          switch (data.user.role) {\n            case \"user\":\n              this.$router.push(\"/user\");\n              break;\n            case \"admin\":\n              this.$router.push(\"/admin\");\n              break;\n            case \"staff\":\n              this.$router.push(\"/staff\");\n              break;\n            default:\n              this.$router.push(\"/\");\n          }\n        }\n      } catch (err) {\n        console.error(\"Auth error:\", err);\n        alert(err.response?.data?.msg || \"Something went wrong. Please try again.\");\n      } finally {\n        this.loading = false;\n      }\n    },\n    forgotPassword() {\n      this.$router.push({\n        name: \"ForgotPassword\"\n      });\n    }\n  }\n};","map":{"version":3,"names":["axios","name","data","isSignup","email","password","isFilled","emailError","passwordError","loading","computed","formTitle","toggleText","toggleLinkText","methods","toggleMode","resetForm","loginWithGoogle","apiUrl","process","env","VUE_APP_API_URL","window","location","origin","href","checkFilled","trim","validateEmail","emailRegex","test","handleSubmit","post","alert","msg","localStorage","setItem","token","JSON","stringify","user","role","toUpperCase","$router","push","err","console","error","response","forgotPassword"],"sources":["C:\\Users\\LENOVO\\Music\\OneDrive\\Pictures\\distribution-agency-project\\frontend\\src\\views\\Login.vue"],"sourcesContent":["<template>\r\n  <div class=\"login-container\">\r\n    <div class=\"overlay\"></div>\r\n    <div class=\"login-form-section\">\r\n      <div :class=\"['login-box', isFilled ? 'box-filled' : '']\">\r\n        <img src=\"@/assets/logo.jpeg\" alt=\"Company Logo\" class=\"logo\" />\r\n        <h2 class=\"form-title\">{{ formTitle }}</h2>\r\n\r\n        <p class=\"signup-link\">\r\n          {{ toggleText }}\r\n          <a href=\"#\" @click.prevent=\"toggleMode\">{{ toggleLinkText }}</a>\r\n        </p>\r\n\r\n        <form\r\n          class=\"login-form\"\r\n          @submit.prevent=\"handleSubmit\"\r\n          @input=\"checkFilled\"\r\n          novalidate\r\n        >\r\n          <label for=\"email\" class=\"sr-only\">Email</label>\r\n          <input\r\n            type=\"email\"\r\n            id=\"email\"\r\n            v-model.trim=\"email\"\r\n            placeholder=\"Enter email\"\r\n            required\r\n            autocomplete=\"username\"\r\n            :aria-invalid=\"emailError ? 'true' : 'false'\"\r\n          />\r\n          <p v-if=\"emailError\" class=\"error\">{{ emailError }}</p>\r\n\r\n          <!-- Password only for login -->\r\n          <div v-if=\"!isSignup\">\r\n            <label for=\"password\" class=\"sr-only\">Password</label>\r\n            <input\r\n              type=\"password\"\r\n              id=\"password\"\r\n              v-model.trim=\"password\"\r\n              placeholder=\"Enter password\"\r\n              required\r\n              autocomplete=\"current-password\"\r\n              :aria-invalid=\"passwordError ? 'true' : 'false'\"\r\n            />\r\n            <p v-if=\"passwordError\" class=\"error\">{{ passwordError }}</p>\r\n          </div>\r\n\r\n          <a\r\n            v-if=\"!isSignup\"\r\n            href=\"#\"\r\n            class=\"forgot-password\"\r\n            @click.prevent=\"forgotPassword\"\r\n          >\r\n            Forgot your password?\r\n          </a>\r\n\r\n          <button type=\"submit\" class=\"login-button\" :disabled=\"loading\">\r\n            <span v-if=\"loading\">Processing...</span>\r\n            <span v-else>{{ isSignup ? \"Sign Up\" : \"Login\" }}</span>\r\n          </button>\r\n        </form>\r\n\r\n        <div class=\"google-login-section\">\r\n          <button class=\"google-button\" @click=\"loginWithGoogle\">\r\n            <img src=\"@/assets/google-icon.png\" alt=\"Google Logo\" />\r\n            Continue with Google\r\n          </button>\r\n        </div>\r\n\r\n        <footer class=\"form-footer\">\r\n          <small>© 2025 CochinDistributors. All rights reserved.</small>\r\n        </footer>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport axios from \"@/utils/axios\";\r\nimport \"@/assets/styles/Login.css\";\r\n\r\nexport default {\r\n  name: \"LoginPage\",\r\n  data() {\r\n    return {\r\n      isSignup: false,\r\n      email: \"\",\r\n      password: \"\",\r\n      isFilled: false,\r\n      emailError: \"\",\r\n      passwordError: \"\",\r\n      loading: false,\r\n    };\r\n  },\r\n  computed: {\r\n    formTitle() {\r\n      return this.isSignup ? \"Sign Up\" : \"Login\";\r\n    },\r\n    toggleText() {\r\n      return this.isSignup\r\n        ? \"Already have an account?\"\r\n        : \"Don’t have an account?\";\r\n    },\r\n    toggleLinkText() {\r\n      return this.isSignup ? \"Login\" : \"Create an account\";\r\n    },\r\n  },\r\n  methods: {\r\n    toggleMode() {\r\n      this.isSignup = !this.isSignup;\r\n      this.resetForm();\r\n    },\r\n    loginWithGoogle() {\r\n      const apiUrl = process.env.VUE_APP_API_URL || window.location.origin;\r\n      window.location.href = `${apiUrl}/api/auth/google`;\r\n    },\r\n    resetForm() {\r\n      this.email = \"\";\r\n      this.password = \"\";\r\n      this.isFilled = false;\r\n      this.emailError = \"\";\r\n      this.passwordError = \"\";\r\n    },\r\n    checkFilled() {\r\n      this.isFilled = this.isSignup\r\n        ? this.email.trim() !== \"\"\r\n        : this.email.trim() !== \"\" && this.password.trim() !== \"\";\r\n    },\r\n    validateEmail(email) {\r\n      const emailRegex = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/;\r\n      return emailRegex.test(email);\r\n    },\r\n    async handleSubmit() {\r\n      this.emailError = \"\";\r\n      this.passwordError = \"\";\r\n\r\n      if (!this.validateEmail(this.email)) {\r\n        this.emailError = \"Please enter a valid email address.\";\r\n        return;\r\n      }\r\n\r\n      this.loading = true;\r\n\r\n      try {\r\n        if (this.isSignup) {\r\n          // Signup\r\n          const { data } = await axios.post(`/api/auth/register-email`, {\r\n            email: this.email,\r\n          });\r\n          alert(\r\n            data.msg || \"A password setup link has been sent to your email.\"\r\n          );\r\n          this.toggleMode();\r\n        } else {\r\n          // Login\r\n          const { data } = await axios.post(`/api/auth/login`, {\r\n            email: this.email,\r\n            password: this.password,\r\n          });\r\n\r\n          // Save token and user info\r\n          localStorage.setItem(\"token\", data.token);\r\n          localStorage.setItem(\"user\", JSON.stringify(data.user));\r\n\r\n          // Dynamic login message\r\n          alert(`${data.user.role.toUpperCase()} login successful!`);\r\n\r\n          // Redirect based on role\r\n          switch (data.user.role) {\r\n            case \"user\":\r\n              this.$router.push(\"/user\");\r\n              break;\r\n            case \"admin\":\r\n              this.$router.push(\"/admin\");\r\n              break;\r\n            case \"staff\":\r\n              this.$router.push(\"/staff\");\r\n              break;\r\n            default:\r\n              this.$router.push(\"/\");\r\n          }\r\n        }\r\n      } catch (err) {\r\n        console.error(\"Auth error:\", err);\r\n        alert(\r\n          err.response?.data?.msg || \"Something went wrong. Please try again.\"\r\n        );\r\n      } finally {\r\n        this.loading = false;\r\n      }\r\n    },\r\n    forgotPassword() {\r\n      this.$router.push({ name: \"ForgotPassword\" });\r\n    },\r\n  },\r\n};\r\n</script>\r\n"],"mappings":";AA6EA,OAAOA,KAAI,MAAO,eAAe;AACjC,OAAO,2BAA2B;AAElC,eAAe;EACbC,IAAI,EAAE,WAAW;EACjBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,QAAQ,EAAE,KAAK;MACfC,KAAK,EAAE,EAAE;MACTC,QAAQ,EAAE,EAAE;MACZC,QAAQ,EAAE,KAAK;MACfC,UAAU,EAAE,EAAE;MACdC,aAAa,EAAE,EAAE;MACjBC,OAAO,EAAE;IACX,CAAC;EACH,CAAC;EACDC,QAAQ,EAAE;IACRC,SAASA,CAAA,EAAG;MACV,OAAO,IAAI,CAACR,QAAO,GAAI,SAAQ,GAAI,OAAO;IAC5C,CAAC;IACDS,UAAUA,CAAA,EAAG;MACX,OAAO,IAAI,CAACT,QAAO,GACf,0BAAyB,GACzB,wBAAwB;IAC9B,CAAC;IACDU,cAAcA,CAAA,EAAG;MACf,OAAO,IAAI,CAACV,QAAO,GAAI,OAAM,GAAI,mBAAmB;IACtD;EACF,CAAC;EACDW,OAAO,EAAE;IACPC,UAAUA,CAAA,EAAG;MACX,IAAI,CAACZ,QAAO,GAAI,CAAC,IAAI,CAACA,QAAQ;MAC9B,IAAI,CAACa,SAAS,CAAC,CAAC;IAClB,CAAC;IACDC,eAAeA,CAAA,EAAG;MAChB,MAAMC,MAAK,GAAIC,OAAO,CAACC,GAAG,CAACC,eAAc,IAAKC,MAAM,CAACC,QAAQ,CAACC,MAAM;MACpEF,MAAM,CAACC,QAAQ,CAACE,IAAG,GAAI,GAAGP,MAAM,kBAAkB;IACpD,CAAC;IACDF,SAASA,CAAA,EAAG;MACV,IAAI,CAACZ,KAAI,GAAI,EAAE;MACf,IAAI,CAACC,QAAO,GAAI,EAAE;MAClB,IAAI,CAACC,QAAO,GAAI,KAAK;MACrB,IAAI,CAACC,UAAS,GAAI,EAAE;MACpB,IAAI,CAACC,aAAY,GAAI,EAAE;IACzB,CAAC;IACDkB,WAAWA,CAAA,EAAG;MACZ,IAAI,CAACpB,QAAO,GAAI,IAAI,CAACH,QAAO,GACxB,IAAI,CAACC,KAAK,CAACuB,IAAI,CAAC,MAAM,EAAC,GACvB,IAAI,CAACvB,KAAK,CAACuB,IAAI,CAAC,MAAM,EAAC,IAAK,IAAI,CAACtB,QAAQ,CAACsB,IAAI,CAAC,MAAM,EAAE;IAC7D,CAAC;IACDC,aAAaA,CAACxB,KAAK,EAAE;MACnB,MAAMyB,UAAS,GAAI,4BAA4B;MAC/C,OAAOA,UAAU,CAACC,IAAI,CAAC1B,KAAK,CAAC;IAC/B,CAAC;IACD,MAAM2B,YAAYA,CAAA,EAAG;MACnB,IAAI,CAACxB,UAAS,GAAI,EAAE;MACpB,IAAI,CAACC,aAAY,GAAI,EAAE;MAEvB,IAAI,CAAC,IAAI,CAACoB,aAAa,CAAC,IAAI,CAACxB,KAAK,CAAC,EAAE;QACnC,IAAI,CAACG,UAAS,GAAI,qCAAqC;QACvD;MACF;MAEA,IAAI,CAACE,OAAM,GAAI,IAAI;MAEnB,IAAI;QACF,IAAI,IAAI,CAACN,QAAQ,EAAE;UACjB;UACA,MAAM;YAAED;UAAK,IAAI,MAAMF,KAAK,CAACgC,IAAI,CAAC,0BAA0B,E